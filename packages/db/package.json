{
  "name": "@ecommerce/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "db:generate": "prisma generate --config ./prisma.config.ts",
    "db:push": "prisma db push --config ./prisma.config.ts",
    "db:migrate": "prisma migrate dev --config ./prisma.config.ts",
    "db:studio": "prisma studio --config ./prisma.config.ts"
  },
  "dependencies": {
    "@prisma/client": "^7.5.0",
    "@prisma/adapter-pg": "^7.5.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "prisma": "^7.5.0",
    "tsx": "^4.20.5"
  }
}